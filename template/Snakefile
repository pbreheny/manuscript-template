from pathlib import Path
ms = "my-paper"
cache = "../cache"

rule all:
    input:
        f"{ms}/{ms}.pdf",
        "supplement/supplement.pdf",
        f"arxiv/build/{ms}.pdf"

rule pdf:
    input:
        f"{ms}.tex",
        "main.tex",
        "math-traditional.tex",
        "ref.bib",
        "results/power.pdf",
        "results/error-rate.tex",
        "smallcap.bst"
    output:
        f"{ms}/{ms}.pdf"
    shell:
        f"""
        latexmk --xelatex -output-directory={ms} -silent {ms}.tex
	texfot xelatex -interaction=nonstopmode -output-directory={ms} -synctex=1 {ms}.tex
        """

rule supplement:
    input:
        "supplement.tex",
        "math-traditional.tex",
        "ref.bib",
        "smallcap.bst"
    output:
        f"supplement/supplement.pdf"
    shell:
        f"""
        latexmk --xelatex -output-directory=supplement -silent supplement.tex
	texfot xelatex -interaction=nonstopmode -output-directory=supplement -synctex=1 supplement.tex
        """

rule arxiv:
    input:
        f"{ms}/{ms}.pdf",
        "code/singletex.r",
        "math-traditional.tex"
    output:
        f"arxiv/build/{ms}.pdf"
    shell:
        f"""
        mkdir -p arxiv/build
        Rscript code/singletex.r {ms}.tex arxiv/{ms}.tex
        cd arxiv
        latexmk --xelatex -output-directory=build -silent {ms}.tex
        texfot xelatex -interaction=nonstopmode -output-directory=build -synctex=1 {ms}.tex
        """

rule power:
    input:
        f"{cache}/ex-100-2.csv",
        "code/power.r"
    output:
        "results/power.pdf"
    shell:
        """
        cd code
        Rscript power.r
        """

rule error_rate:
    input:
        f"{cache}/ex-100-2.csv",
        "code/error-rate.r"
    output:
        "results/error-rate.tex"
    shell:
        """
        cd code
        Rscript error-rate.r
        """

rule math:
    output:
        "math-traditional.tex"
    shell:
        "curl -O https://raw.githubusercontent.com/pbreheny/pb-latex/main/tex/math-traditional.tex"

rule bst:
    output:
        "smallcap.bst"
    shell:
        "curl -O https://raw.githubusercontent.com/pbreheny/pb-latex/main/bst/smallcap.bst"
